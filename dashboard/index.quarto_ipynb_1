        "from itables import show\n",
        "import itables.options as opt\n",
        "\n",
        "# Activar opciones DataTables (sin wrap de texto, compacta)\n",
        "opt.classes = [\"display\", \"nowrap\", \"compact\"]\n",
        "opt.lengthMenu = [5, 10, 30]\n",
        "opt.pageLength = 5  # Mostrar 5 filas por defecto para no saturar el panel\n",
